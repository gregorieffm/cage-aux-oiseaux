---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';

let stats = { totalBookings: 0, pendingBookings: 0, paidBookings: 0, totalRevenue: 0, recentBookings: [] as any[], contactCount: 0 };

if (supabaseAdmin) {
  const [bookingsRes, paidRes, contactsRes, recentRes] = await Promise.all([
    supabaseAdmin.from('bookings').select('id, status', { count: 'exact', head: true }),
    supabaseAdmin.from('bookings').select('total_cents').in('status', ['paid', 'completed']),
    supabaseAdmin.from('contact_submissions').select('id', { count: 'exact', head: true }).eq('read', false),
    supabaseAdmin
      .from('bookings')
      .select('id, guest_name, guest_email, check_in, check_out, total_cents, status, created_at, properties(name)')
      .order('created_at', { ascending: false })
      .limit(5),
  ]);

  const pendingRes = await supabaseAdmin.from('bookings').select('id', { count: 'exact', head: true }).eq('status', 'pending');

  stats = {
    totalBookings: bookingsRes.count || 0,
    pendingBookings: pendingRes.count || 0,
    paidBookings: paidRes.data?.length || 0,
    totalRevenue: paidRes.data?.reduce((sum, b) => sum + b.total_cents, 0) || 0,
    recentBookings: recentRes.data || [],
    contactCount: contactsRes.count || 0,
  };
}

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' });
}
---

<AdminLayout title="Tableau de bord" activeNav="dashboard">
  <div class="stat-grid">
    <div class="stat-card">
      <div class="stat-card__label">Réservations totales</div>
      <div class="stat-card__value">{stats.totalBookings}</div>
    </div>
    <div class="stat-card">
      <div class="stat-card__label">En attente</div>
      <div class="stat-card__value">{stats.pendingBookings}</div>
    </div>
    <div class="stat-card">
      <div class="stat-card__label">Payées</div>
      <div class="stat-card__value">{stats.paidBookings}</div>
    </div>
    <div class="stat-card">
      <div class="stat-card__label">Chiffre d'affaires</div>
      <div class="stat-card__value">{(stats.totalRevenue / 100).toLocaleString('fr-FR')} €</div>
    </div>
  </div>

  {stats.contactCount > 0 && (
    <div class="card" style="margin-bottom:16px; border-left: 3px solid var(--admin-warning);">
      <div class="card__body" style="display:flex;align-items:center;justify-content:space-between;">
        <span><strong>{stats.contactCount}</strong> message{stats.contactCount > 1 ? 's' : ''} non lu{stats.contactCount > 1 ? 's' : ''}</span>
        <a href="/admin/contacts" class="btn-admin btn-admin--sm">Voir</a>
      </div>
    </div>
  )}

  <div class="card">
    <div class="card__header">
      <span class="card__title">Dernières réservations</span>
      <a href="/admin/bookings" class="btn-admin btn-admin--sm">Tout voir</a>
    </div>
    {stats.recentBookings.length > 0 ? (
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Client</th>
              <th>Hébergement</th>
              <th>Dates</th>
              <th>Total</th>
              <th>Statut</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {stats.recentBookings.map(b => (
              <tr>
                <td>
                  <div style="font-weight:500">{b.guest_name}</div>
                  <div style="font-size:12px;color:var(--admin-text-light)">{b.guest_email}</div>
                </td>
                <td>{(b.properties as any)?.name || '—'}</td>
                <td>{formatDate(b.check_in)} → {formatDate(b.check_out)}</td>
                <td style="font-weight:600">{(b.total_cents / 100).toFixed(0)} €</td>
                <td><span class={`badge badge--${b.status}`}>{b.status}</span></td>
                <td><a href={`/admin/bookings/${b.id}`} class="btn-admin btn-admin--sm">Détails</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      <div class="empty-state">
        <p>Aucune réservation pour le moment.</p>
      </div>
    )}
  </div>
</AdminLayout>
