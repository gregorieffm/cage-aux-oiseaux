---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabaseAdmin } from '../../../lib/supabase';

const { id } = Astro.params;

const { data: booking } = await supabaseAdmin!
  .from('bookings')
  .select('*, properties(name, slug)')
  .eq('id', id)
  .single();

if (!booking) return Astro.redirect('/admin/bookings');

const p = booking.properties as any;
const nights = Math.round((new Date(booking.check_out).getTime() - new Date(booking.check_in).getTime()) / (1000 * 60 * 60 * 24));

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
}
function formatDateTime(d: string) {
  return new Date(d).toLocaleString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
}

const statusActions: Record<string, { label: string; next: string; style: string }[]> = {
  pending: [
    { label: 'Confirmer', next: 'confirmed', style: 'btn-admin--primary' },
    { label: 'Annuler', next: 'cancelled', style: 'btn-admin--danger' },
  ],
  confirmed: [
    { label: 'Marquer payée', next: 'paid', style: 'btn-admin--primary' },
    { label: 'Annuler', next: 'cancelled', style: 'btn-admin--danger' },
  ],
  paid: [
    { label: 'Marquer terminée', next: 'completed', style: 'btn-admin--primary' },
    { label: 'Annuler / Rembourser', next: 'cancelled', style: 'btn-admin--danger' },
  ],
  completed: [],
  cancelled: [],
};

const actions = statusActions[booking.status] || [];
---

<AdminLayout title={`Réservation #${booking.id.slice(0, 8)}`} activeNav="bookings">
  <a href="/admin/bookings" style="display:inline-block;margin-bottom:16px;font-size:13px;color:var(--admin-text-light)">&larr; Retour aux réservations</a>

  <div style="display:grid;grid-template-columns:1fr 340px;gap:20px;align-items:start">
    <div>
      <!-- Booking details -->
      <div class="card" style="margin-bottom:20px">
        <div class="card__header">
          <span class="card__title">Détails de la réservation</span>
          <span class={`badge badge--${booking.status}`}>{booking.status}</span>
        </div>
        <div class="card__body">
          <div class="detail-grid">
            <div class="detail-row">
              <span class="detail-label">Hébergement</span>
              <span class="detail-value">{p?.name || '—'}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Arrivée</span>
              <span class="detail-value">{formatDate(booking.check_in)}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Départ</span>
              <span class="detail-value">{formatDate(booking.check_out)}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Nuits</span>
              <span class="detail-value">{nights}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Prix / nuit</span>
              <span class="detail-value">{(booking.price_per_night_cents / 100).toFixed(0)} €</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Total</span>
              <span class="detail-value" style="font-weight:700;font-size:18px">{(booking.total_cents / 100).toFixed(0)} €</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Guest info -->
      <div class="card" style="margin-bottom:20px">
        <div class="card__header">
          <span class="card__title">Client</span>
        </div>
        <div class="card__body">
          <div class="detail-grid">
            <div class="detail-row">
              <span class="detail-label">Nom</span>
              <span class="detail-value">{booking.guest_name}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Email</span>
              <span class="detail-value"><a href={`mailto:${booking.guest_email}`} style="color:var(--admin-primary)">{booking.guest_email}</a></span>
            </div>
            {booking.guest_phone && (
              <div class="detail-row">
                <span class="detail-label">Téléphone</span>
                <span class="detail-value"><a href={`tel:${booking.guest_phone}`} style="color:var(--admin-primary)">{booking.guest_phone}</a></span>
              </div>
            )}
            {booking.guest_message && (
              <div class="detail-row">
                <span class="detail-label">Message</span>
                <span class="detail-value">{booking.guest_message}</span>
              </div>
            )}
          </div>
        </div>
      </div>

      <!-- Payment info -->
      {(booking.stripe_payment_intent_id || booking.paid_at) && (
        <div class="card">
          <div class="card__header"><span class="card__title">Paiement</span></div>
          <div class="card__body">
            <div class="detail-grid">
              {booking.stripe_payment_intent_id && (
                <div class="detail-row">
                  <span class="detail-label">Stripe ID</span>
                  <span class="detail-value" style="font-family:monospace;font-size:12px">{booking.stripe_payment_intent_id}</span>
                </div>
              )}
              {booking.paid_at && (
                <div class="detail-row">
                  <span class="detail-label">Payé le</span>
                  <span class="detail-value">{formatDateTime(booking.paid_at)}</span>
                </div>
              )}
            </div>
          </div>
        </div>
      )}
    </div>

    <!-- Sidebar: Actions + Notes -->
    <div>
      {actions.length > 0 && (
        <div class="card" style="margin-bottom:20px">
          <div class="card__header"><span class="card__title">Actions</span></div>
          <div class="card__body" style="display:flex;flex-direction:column;gap:8px">
            {actions.map(a => (
              <button
                class={`btn-admin ${a.style}`}
                style="width:100%;justify-content:center"
                data-action={a.next}
                data-booking={booking.id}
              >
                {a.label}
              </button>
            ))}
          </div>
        </div>
      )}

      <div class="card">
        <div class="card__header"><span class="card__title">Notes admin</span></div>
        <div class="card__body">
          <textarea
            id="adminNotes"
            style="width:100%;min-height:100px;padding:8px;border:1px solid var(--admin-border);border-radius:6px;font-family:inherit;font-size:13px;resize:vertical"
            placeholder="Notes internes..."
          >{booking.admin_notes || ''}</textarea>
          <button class="btn-admin btn-admin--sm" style="margin-top:8px" id="saveNotes" data-booking={booking.id}>
            Enregistrer
          </button>
        </div>
      </div>

      <div style="margin-top:16px;font-size:11px;color:var(--admin-text-light)">
        <div>Créée le {formatDateTime(booking.created_at)}</div>
        {booking.cancelled_at && <div>Annulée le {formatDateTime(booking.cancelled_at)}</div>}
      </div>
    </div>
  </div>
</AdminLayout>

<style>
  .detail-grid { display: flex; flex-direction: column; gap: 12px; }
  .detail-row { display: flex; justify-content: space-between; align-items: baseline; }
  .detail-label { font-size: 12px; color: var(--admin-text-light); }
  .detail-value { font-size: 14px; font-weight: 500; text-align: right; max-width: 60%; }
</style>

<script>
  document.querySelectorAll('[data-action]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const action = (btn as HTMLElement).dataset.action;
      const bookingId = (btn as HTMLElement).dataset.booking;
      if (!confirm(`Changer le statut en "${action}" ?`)) return;

      (btn as HTMLButtonElement).disabled = true;
      (btn as HTMLButtonElement).textContent = '...';

      const res = await fetch('/api/admin/bookings', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ bookingId, status: action }),
      });

      if (res.ok) {
        window.location.reload();
      } else {
        alert('Erreur lors de la mise à jour');
        (btn as HTMLButtonElement).disabled = false;
      }
    });
  });

  document.getElementById('saveNotes')?.addEventListener('click', async (e) => {
    const btn = e.target as HTMLButtonElement;
    const bookingId = btn.dataset.booking;
    const notes = (document.getElementById('adminNotes') as HTMLTextAreaElement).value;

    btn.disabled = true;
    btn.textContent = '...';

    const res = await fetch('/api/admin/bookings', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ bookingId, adminNotes: notes }),
    });

    btn.disabled = false;
    btn.textContent = res.ok ? 'Enregistré !' : 'Erreur';
    setTimeout(() => { btn.textContent = 'Enregistrer'; }, 2000);
  });
</script>
