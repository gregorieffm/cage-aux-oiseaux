---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Domaine La Cage aux Oiseaux — Séjour insolite en Normandie',
  description = "Chambres d'hôtes, cabanes, spa privatif et atelier céramique au coeur de la Normandie. Un lieu vivant façonné par la nature et l'univers artistique de Coco Eugène Lacroix.",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
