---
import { getEntry } from 'astro:content';
const { data: d } = await getEntry('sections', 'domaine');
---

<section class="section domaine" id="domaine">
  <div class="container">
    <div class="split split--reverse">
      <div class="split__media">
        <video
          class="domaine-video"
          autoplay
          muted
          loop
          playsinline
          poster=""
        >
          <source src="/images/domaine-video.mp4" type="video/mp4" />
        </video>
      </div>
      <div class="split__text">
        <span class="section__label">{d.label}</span>
        <h2 class="section__title" set:html={d.title.replace(' hors', '<br />hors')} />
        {d.paragraphs.map(p => <p>{p}</p>)}
      </div>
    </div>
  </div>
</section>

<style>
  .domaine-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-lg);
    min-height: 400px;
    max-height: 600px;
  }
  @media (max-width: 768px) {
    .domaine-video {
      min-height: 250px;
      max-height: 350px;
    }
  }
</style>
