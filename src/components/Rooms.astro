---
import { getCollection } from 'astro:content';
import RoomCard from './RoomCard.astro';

const allProperties = await getCollection('properties');
const rooms = allProperties
  .sort((a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return a.data.order - b.data.order;
  })
  .map(p => p.data);
---

<section class="section hebergements" id="hebergements">
  <div class="container">
    <div class="section__header">
      <span class="section__label">Séjours insolites</span>
      <h2 class="section__title">Nos hébergements</h2>
      <p class="section__intro">Le domaine abrite {rooms.length} chambres d'hôtes labellisées Gîtes de France. Chacune propose une ambiance unique, entre confort, nature et esprit maison de famille.</p>
    </div>
    <div class="rooms">
      {rooms.map(room => (
        <RoomCard
          name={room.name}
          slug={room.slug}
          capacity={room.capacity}
          description={room.description}
          features={room.features}
          price={room.price}
          badge={room.badge}
          featured={room.featured}
          image={room.image}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .hebergements { background: var(--c-bg-warm); }
  .rooms {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: var(--space-lg);
  }
  @media (max-width: 768px) {
    .rooms { grid-template-columns: 1fr; }
  }
</style>
