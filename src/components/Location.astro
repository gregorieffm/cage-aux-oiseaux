---
import { getEntry } from 'astro:content';
const { data: content } = await getEntry('sections', 'site-content');
const loc = content.location;
---

<section class="section location">
  <div class="container">
    <div class="split">
      <div class="split__text">
        <span class="section__label">{loc.label}</span>
        <h2 class="section__title" set:html={loc.title.replace(' de', ' de<br />')} />
        <address set:html={loc.address.map(l => `<strong>${l}</strong>`).join('<br />').replace(/<strong>(?!Domaine)/g, ''). replace(/<\/strong>(?!<br)(?!$)/g, '')} />
        <ul class="location__nearby">
          {loc.nearby.map(n => <li>{n}</li>)}
        </ul>
      </div>
      <div class="split__media">
        <div class="map-container">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5240!2d-0.049!3d48.585!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x480e9e8a1b9f1c3d%3A0x0!2s2%20Chemin%20des%20Fleurs%2C%2061320%20La%20Lande-de-Goult!5e0!3m2!1sfr!2sfr"
            width="100%"
            height="100%"
            style="border:0"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Domaine La Cage aux Oiseaux — 2 Chemin des Fleurs, 61320 La Lande-de-Goult"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .location { background: var(--c-bg-warm); }
  .location address {
    font-size: var(--fs-md);
    line-height: 1.8;
    color: var(--c-text-light);
    margin-bottom: var(--space-md);
  }
  .location__nearby { margin-top: var(--space-sm); }
  .location__nearby li {
    font-size: var(--fs-sm);
    color: var(--c-text-light);
    padding: 0.4em 0;
    border-bottom: 1px solid var(--c-cream);
  }
  .location__nearby li:last-child { border: none; }
  .map-container {
    width: 100%;
    height: 100%;
    min-height: 400px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }
  @media (max-width: 768px) {
    .map-container { min-height: 300px; }
  }
</style>
