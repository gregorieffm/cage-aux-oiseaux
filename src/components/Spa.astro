---
import { getEntry } from 'astro:content';
const { data: content } = await getEntry('sections', 'site-content');
const spa = content.spa;
const allImages = [spa.image, ...(spa.gallery || [])].filter(Boolean);
---

<section class="section spa" id="spa">
  <div class="container">
    <div class="split">
      <div class="split__text">
        <span class="section__label">{spa.label}</span>
        <h2 class="section__title" set:html={spa.title.replace('&', '&amp;<br />')} />
        {spa.paragraphs.map(p => <p>{p}</p>)}
        <div class="spa__options">
          {spa.options.map(opt => (
            <div class="spa__option">
              <h4>{opt.name}</h4>
              <p>{opt.description}{opt.price && <><br /><strong>{opt.price}</strong></>}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="split__media">
        {allImages.length > 0 ? (
          <div class="spa-gallery" id="spaGallery">
            <div class="spa-gallery__main">
              <img src={allImages[0]} alt={spa.title} class="spa-gallery__img" id="spaMainImg" loading="lazy" />
              {allImages.length > 1 && (
                <>
                  <button class="spa-gallery__arrow spa-gallery__arrow--prev" id="spaPrev" aria-label="Précédent">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
                  </button>
                  <button class="spa-gallery__arrow spa-gallery__arrow--next" id="spaNext" aria-label="Suivant">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                  </button>
                  <span class="spa-gallery__counter" id="spaCounter">1 / {allImages.length}</span>
                </>
              )}
            </div>
            {allImages.length > 1 && (
              <div class="spa-gallery__dots">
                {allImages.map((_, i) => (
                  <button class={`spa-gallery__dot ${i === 0 ? 'spa-gallery__dot--active' : ''}`} data-idx={i} aria-label={`Photo ${i+1}`}></button>
                ))}
              </div>
            )}
          </div>
        ) : (
          <div class="img-placeholder img-placeholder--tall" data-label="Spa"></div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .spa { background: var(--c-bg); }
  .spa__options {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }
  .spa__option {
    padding: var(--space-md);
    background: var(--c-bg-warm);
    border-radius: var(--radius-md);
    border-left: 3px solid var(--c-accent);
  }
  .spa__option h4 {
    font-family: var(--ff-display);
    font-size: var(--fs-md);
    font-weight: 500;
    margin-bottom: 0.3em;
  }
  .spa__option p {
    font-size: var(--fs-sm);
    color: var(--c-text-light);
    margin: 0 !important;
  }
  .spa-gallery__main {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 3/4;
  }
  .spa-gallery__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.3s;
  }
  .spa-gallery__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.85);
    border: none;
    border-radius: 50%;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    z-index: 2;
    color: var(--c-text);
    transition: all 0.2s;
  }
  .spa-gallery__arrow:hover { background: white; }
  .spa-gallery__arrow--prev { left: 10px; }
  .spa-gallery__arrow--next { right: 10px; }
  .spa-gallery__counter {
    position: absolute;
    bottom: 10px;
    right: 10px;
    background: rgba(0,0,0,0.5);
    color: white;
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 12px;
    z-index: 2;
  }
  .spa-gallery__dots {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: 10px;
  }
  .spa-gallery__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: var(--c-cream);
    cursor: pointer;
    padding: 0;
    transition: all 0.2s;
  }
  .spa-gallery__dot--active { background: var(--c-accent); transform: scale(1.3); }
</style>

<script define:vars={{ spaImages: allImages }}>
  const mainImg = document.getElementById('spaMainImg');
  const counter = document.getElementById('spaCounter');
  const dots = document.querySelectorAll('.spa-gallery__dot');
  let idx = 0;

  function goTo(i) {
    idx = ((i % spaImages.length) + spaImages.length) % spaImages.length;
    if (mainImg) mainImg.src = spaImages[idx];
    if (counter) counter.textContent = `${idx + 1} / ${spaImages.length}`;
    dots.forEach((d, j) => d.classList.toggle('spa-gallery__dot--active', j === idx));
  }

  document.getElementById('spaPrev')?.addEventListener('click', () => goTo(idx - 1));
  document.getElementById('spaNext')?.addEventListener('click', () => goTo(idx + 1));
  dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));

  let touchX = 0;
  document.getElementById('spaGallery')?.addEventListener('touchstart', e => { touchX = e.touches[0].clientX; }, { passive: true });
  document.getElementById('spaGallery')?.addEventListener('touchend', e => {
    const diff = touchX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) goTo(diff > 0 ? idx + 1 : idx - 1);
  }, { passive: true });
</script>
