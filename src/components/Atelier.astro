---
import { getEntry } from 'astro:content';
const { data: content } = await getEntry('sections', 'site-content');
const a = content.atelier;
---

<section class="section atelier" id="atelier">
  <div class="container">
    <div class="section__header">
      <span class="section__label">{a.label}</span>
      <h2 class="section__title">{a.title}</h2>
      <p class="section__intro">{a.intro}</p>
    </div>

    <div class="atelier__grid">
      <div class="atelier__item">
        <img src="/images/property/general-garden1.jpg" alt="Sculptures en grès" style="width:100%;height:100%;object-fit:cover;border-radius:var(--radius-lg)" loading="lazy" />
      </div>
      <div class="atelier__item">
        <img src="/images/property/general-garden2.jpg" alt="Bols & céramiques" style="width:100%;height:100%;object-fit:cover;border-radius:var(--radius-lg)" loading="lazy" />
      </div>
      <div class="atelier__item atelier__item--text">
        <h3>Un lieu vivant</h3>
        {a.galleryText.map(p => <p>{p}</p>)}
      </div>
      <div class="atelier__item">
        <img src="/images/property/general-interior1.jpg" alt="Déco de jardin" style="width:100%;height:100%;object-fit:cover;border-radius:var(--radius-lg)" loading="lazy" />
      </div>
      <div class="atelier__item">
        <img src="/images/property/img-11.jpg" alt="L'atelier" style="width:100%;height:100%;object-fit:cover;border-radius:var(--radius-lg)" loading="lazy" />
      </div>
    </div>

    <div class="atelier__deco">
      <h3>{a.decoTitle}</h3>
      <p>{a.decoDescription}</p>
    </div>
  </div>
</section>

<style>
  .atelier { background: var(--c-bg-warm); }
  .atelier__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }
  .atelier__item--text {
    background: var(--c-white);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .atelier__item--text h3 {
    font-family: var(--ff-display);
    font-size: var(--fs-xl);
    font-weight: 400;
    margin-bottom: var(--space-sm);
  }
  .atelier__item--text p {
    font-size: var(--fs-sm);
    color: var(--c-text-light);
    margin-bottom: var(--space-xs);
  }
  .atelier__deco {
    text-align: center;
    padding: var(--space-lg);
    background: var(--c-white);
    border-radius: var(--radius-md);
  }
  .atelier__deco h3 {
    font-family: var(--ff-display);
    font-size: var(--fs-lg);
    font-weight: 400;
    margin-bottom: var(--space-xs);
  }
  .atelier__deco p {
    color: var(--c-text-light);
    font-size: var(--fs-sm);
  }
  @media (max-width: 1024px) {
    .atelier__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .atelier__grid { grid-template-columns: 1fr; }
  }
</style>
