---
interface Props {
  name: string;
  slug: string;
  capacity: string;
  description: string;
  features: string[];
  price?: string;
  badge?: string;
  featured?: boolean;
  image?: string;
}

const { name, slug, capacity, description, features, price, badge, featured = false, image } = Astro.props;
---

<article class:list={['room-card', { 'room-card--featured': featured }]}>
  <a href={`/booking/${slug}`} class="room-card__media">
    {image
      ? <img src={image} alt={name} class="room-card__img" loading="lazy" />
      : <div class="img-placeholder img-placeholder--wide" data-label={name}></div>
    }
    {badge && <span class="room-card__badge">{badge}</span>}
  </a>
  <div class="room-card__body">
    <h3 class="room-card__name"><a href={`/booking/${slug}`}>{name}</a></h3>
    <p class="room-card__capacity">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
        <circle cx="9" cy="7" r="4"/>
      </svg>
      {capacity}
    </p>
    <p>{description}</p>
    <ul class="room-card__features">
      {features.map(f => <li>{f}</li>)}
    </ul>
    <div class="room-card__footer">
      {price && (
        <span class="room-card__price">À partir de <strong>{price}</strong> / nuit</span>
      )}
      <a href={`/booking/${slug}`} class="btn btn--small">Réserver</a>
    </div>
  </div>
</article>

<style>
  .room-card {
    background: var(--c-white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
  }
  .room-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }
  .room-card--featured {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }
  .room-card__media { position: relative; overflow: hidden; aspect-ratio: 4/3; }
  .room-card--featured .room-card__media { aspect-ratio: auto; }
  .room-card__media .img-placeholder { height: 100%; border-radius: 0; }
  .room-card__img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .room-card__badge {
    position: absolute;
    top: var(--space-md);
    left: var(--space-md);
    background: var(--c-accent);
    color: var(--c-white);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.4em 1em;
    border-radius: var(--radius-sm);
    z-index: 1;
  }
  .room-card__body { padding: var(--space-lg); min-width: 0; }
  .room-card__media { display: block; }
  .room-card__name {
    font-family: var(--ff-display);
    font-size: var(--fs-xl);
    font-weight: 400;
    margin-bottom: var(--space-xs);
  }
  .room-card__name a { color: inherit; transition: color 0.2s; }
  .room-card__name a:hover { color: var(--c-accent); }
  .room-card__capacity {
    display: flex;
    align-items: center;
    gap: 0.4em;
    font-size: var(--fs-sm);
    color: var(--c-text-light);
    margin-bottom: var(--space-sm);
  }
  .room-card__body > p {
    color: var(--c-text-light);
    font-size: var(--fs-sm);
    margin-bottom: var(--space-md);
  }
  .room-card__features {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-bottom: var(--space-md);
  }
  .room-card__features li {
    background: var(--c-green-light);
    color: var(--c-green);
    font-size: var(--fs-xs);
    font-weight: 500;
    padding: 0.3em 0.8em;
    border-radius: var(--radius-xl);
  }
  .room-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-md);
    border-top: 1px solid var(--c-cream);
  }
  .room-card__price {
    font-size: var(--fs-sm);
    color: var(--c-text-light);
  }
  .room-card__price strong {
    font-size: var(--fs-lg);
    color: var(--c-text);
    font-family: var(--ff-display);
  }
  @media (max-width: 1024px) {
    .room-card--featured { grid-template-columns: 1fr; }
  }
</style>
