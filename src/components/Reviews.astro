---
import { getEntry } from 'astro:content';
const { data: r } = await getEntry('sections', 'reviews');
---

<section class="section reviews">
  <div class="container">
    <div class="section__header">
      <span class="section__label">{r.label}</span>
      <h2 class="section__title">{r.title}</h2>
      <p class="section__intro">{r.subtitle}</p>
    </div>
    <div class="reviews__grid">
      {r.items.map(review => (
        <blockquote class="review">
          <div class="review__stars">{'★'.repeat(review.rating)}</div>
          <p>&laquo; {review.text} &raquo;</p>
          <cite>— {review.author}</cite>
        </blockquote>
      ))}
    </div>
  </div>
</section>

<style>
  .reviews { background: var(--c-bg); }
  .reviews__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-lg);
  }
  .review {
    background: var(--c-white);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    box-shadow: var(--shadow-sm);
  }
  .review__stars {
    color: var(--c-accent-light);
    font-size: var(--fs-md);
    margin-bottom: var(--space-sm);
    letter-spacing: 2px;
  }
  .review p {
    font-family: var(--ff-display);
    font-size: var(--fs-md);
    font-style: italic;
    line-height: 1.6;
    color: var(--c-text);
    margin-bottom: var(--space-sm);
  }
  .review cite {
    font-style: normal;
    font-size: var(--fs-sm);
    color: var(--c-text-light);
  }
  @media (max-width: 768px) {
    .reviews__grid { grid-template-columns: 1fr; }
  }
</style>
