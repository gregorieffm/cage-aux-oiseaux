---
import { getCollection, getEntry } from 'astro:content';
import RoomCard from './RoomCard.astro';

const { data: gitesMeta } = await getEntry('sections', 'gites');
const allProperties = await getCollection('properties');
const gites = allProperties
  .filter(p => (p.data.category || 'chambre') === 'gite')
  .sort((a, b) => a.data.order - b.data.order)
  .map(p => p.data);
---

<section class="section gites" id="gites">
  <div class="container">
    <div class="section__header">
      <span class="section__label">{gitesMeta.label}</span>
      <h2 class="section__title">{gitesMeta.title}</h2>
    </div>
    <div class="gites__grid">
      {gites.map(g => (
        <RoomCard
          name={g.name}
          slug={g.slug}
          capacity={g.capacity}
          description={g.description}
          features={g.features}
          price={g.price}
          image={g.image}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .gites { background: var(--c-bg-warm); }
  .gites__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-lg);
  }
  @media (max-width: 768px) {
    .gites__grid { grid-template-columns: 1fr; }
  }
</style>
