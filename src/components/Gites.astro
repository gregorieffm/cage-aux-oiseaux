---
import { getEntry } from 'astro:content';
const { data: gites } = await getEntry('sections', 'gites');
---

<section class="section gites" id="gites">
  <div class="container">
    <div class="section__header">
      <span class="section__label">{gites.label}</span>
      <h2 class="section__title">{gites.title}</h2>
    </div>
    <div class="gites__grid">
      {gites.items.map(g => (
        <div class="gite-card">
          <div class="gite-card__media">
            {g.image
              ? <img src={g.image} alt={g.name} class="gite-card__img" loading="lazy" />
              : <div class="img-placeholder img-placeholder--wide" data-label={g.name}></div>
            }
          </div>
          <div class="gite-card__body">
            <h3 class="gite-card__name">{g.name}</h3>
            <span class="gite-card__location">{g.location}</span>
            <p class="gite-card__type">{g.type}</p>
            <p class="gite-card__desc">{g.description}</p>
            {g.url && (
              <a href={g.url} target="_blank" rel="noopener noreferrer" class="btn btn--small">Découvrir</a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .gites { background: var(--c-bg-warm); }
  .gites__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-lg);
  }
  .gite-card {
    background: var(--c-white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
  }
  .gite-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }
  .gite-card__media { aspect-ratio: 4/3; overflow: hidden; }
  .gite-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .gite-card__media .img-placeholder { height: 100%; border-radius: 0; }
  .gite-card__body { padding: var(--space-md); }
  .gite-card__name {
    font-family: var(--ff-display);
    font-size: var(--fs-lg);
    font-weight: 400;
    font-style: italic;
    margin-bottom: 0.2em;
  }
  .gite-card__location {
    display: block;
    font-size: var(--fs-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--c-text-light);
    margin-bottom: 0.3em;
  }
  .gite-card__type {
    font-size: var(--fs-sm);
    color: var(--c-text-light);
    margin-bottom: var(--space-sm);
  }
  .gite-card__desc {
    font-size: var(--fs-sm);
    color: var(--c-text-light);
    line-height: 1.6;
    margin-bottom: var(--space-md);
  }
  @media (max-width: 768px) {
    .gites__grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .gites__grid { grid-template-columns: 1fr; }
  }
</style>
