---
import { getEntry } from 'astro:content';
const { data: s } = await getEntry('sections', 'stages');
---

<section class="section stages" id="stages">
  <div class="container">
    <div class="split split--reverse">
      <div class="split__media">
        {s.image
          ? <img src={s.image} alt={s.title} style="width:100%;height:100%;object-fit:cover;border-radius:var(--radius-lg);min-height:400px" loading="lazy" />
          : <div class="img-placeholder img-placeholder--tall" data-label="Stage céramique"></div>
        }
      </div>
      <div class="split__text">
        <span class="section__label">{s.label}</span>
        <h2 class="section__title" set:html={s.title.replace(' de', ' de<br />')} />
        <p>{s.description}</p>

        <div class="stages__cards">
          {s.formulas.map(f => (
            <div class="stage-card">
              <h4>{f.name}</h4>
              <p>{f.hours}</p>
              <span class="stage-card__price">{f.price}</span>
              <small>{f.note}</small>
            </div>
          ))}
        </div>

        <a href="#contact" class="btn btn--outline">Réserver un stage</a>
      </div>
    </div>
  </div>
</section>

<style>
  .stages { background: var(--c-bg); }
  .stages__cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }
  .stage-card {
    background: var(--c-bg-warm);
    border-radius: var(--radius-md);
    padding: var(--space-md);
    text-align: center;
  }
  .stage-card h4 {
    font-family: var(--ff-display);
    font-size: var(--fs-md);
    font-weight: 500;
    margin-bottom: 0.2em;
  }
  .stage-card p {
    font-size: var(--fs-sm);
    color: var(--c-text-light);
    margin-bottom: var(--space-xs) !important;
  }
  .stage-card__price {
    display: block;
    font-family: var(--ff-display);
    font-size: var(--fs-xl);
    color: var(--c-accent);
    margin-bottom: 0.1em;
  }
  .stage-card small {
    font-size: var(--fs-xs);
    color: var(--c-text-light);
  }
  @media (max-width: 768px) {
    .stages__cards { grid-template-columns: 1fr; }
  }
</style>
